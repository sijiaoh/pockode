{
  "name": "pockode",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others -n server,web -c blue,green \"pnpm:dev:server\" \"pnpm:dev:web\"",
    "dev:server": "cd server && go run .",
    "dev:web": "cd web && pnpm run dev",
    "dev:cluster": "concurrently --kill-others -n server,web -c blue,green \"pnpm:dev:cluster:server\" \"pnpm:dev:cluster:web\"",
    "dev:cluster:server": "cd server && go run . cluster",
    "dev:cluster:web": "cd web-cluster && pnpm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
