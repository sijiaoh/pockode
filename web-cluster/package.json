{
	"name": "pockode-cluster",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"build:release": "tsc && vite build --outDir ../server/cluster/static --emptyOutDir",
		"preview": "vite preview",
		"lint": "biome check src",
		"format": "biome format --write src"
	},
	"dependencies": {
		"@pockode/shared-ui": "workspace:*",
		"json-rpc-2.0": "^1.7.1",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.5",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"tailwindcss": "^4.1.18",
		"typescript": "~5.9.3",
		"vite": "^7.2.4",
		"vite-plugin-compression": "^0.5.1"
	},
	"engines": {
		"node": ">=22"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
